# IVT Kinetics Analyzer - Environment Configuration
# Copy this file to .env and customize values

# ──────────────────────────────────────────────────────
# Development Settings (defaults are fine for local dev)
# ──────────────────────────────────────────────────────

# Flask environment (development, production, testing)
FLASK_ENV=development

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Debug mode (enables hot reload and verbose errors)
DEBUG=true

# ──────────────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────────────

# Host and port for the Dash server
# Dev default: 127.0.0.1 (localhost only)
# Production: set to 0.0.0.0 (Tailscale firewall restricts access)
HOST=127.0.0.1
PORT=8050

# ──────────────────────────────────────────────────────
# Production Settings (uncomment and set for deployment)
# ──────────────────────────────────────────────────────

# REQUIRED in production — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=

# HMAC signing key for publication certificate signatures
# REQUIRED in production — generate the same way as SECRET_KEY
# IVT_SIGNING_KEY=

# Optional: PIN-based access gate — locks the UI behind a login page
# Use a strong PIN (6+ digits recommended)
# IVT_ACCESS_PIN=
